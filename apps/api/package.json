{
  "name": "@ordr/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "@ordr/core": "workspace:*",
    "@ordr/crypto": "workspace:*",
    "@ordr/auth": "workspace:*",
    "@ordr/audit": "workspace:*",
    "@ordr/db": "workspace:*",
    "@ordr/events": "workspace:*",
    "@ordr/compliance": "workspace:*",
    "@ordr/channels": "workspace:*",
    "@ordr/graph": "workspace:*",
    "@ordr/analytics": "workspace:*",
    "@ordr/agent-runtime": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
