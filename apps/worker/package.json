{
  "name": "@ordr/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ordr/core": "workspace:*",
    "@ordr/crypto": "workspace:*",
    "@ordr/events": "workspace:*",
    "@ordr/integrations": "workspace:*",
    "@ordr/agent-runtime": "workspace:*",
    "@ordr/graph": "workspace:*",
    "@ordr/compliance": "workspace:*",
    "@ordr/audit": "workspace:*",
    "@ordr/channels": "workspace:*",
    "@ordr/ai": "workspace:*",
    "@ordr/db": "workspace:*",
    "@ordr/decision-engine": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "kafkajs": "^2.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
