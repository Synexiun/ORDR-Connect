# ============================================================
# ORDR-Connect Environment Variables
# SOC2/ISO27001/HIPAA: Never commit actual values.
# Copy to .env and fill in. Secrets MUST come from Vault in prod.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
API_VERSION=v1

# --- Database (PostgreSQL 16+ with TLS) ---
DATABASE_URL=postgresql://ordr:CHANGE_ME@localhost:5432/ordr_connect?sslmode=require
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_TLS_ENABLED=false

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ordr-connect
KAFKA_GROUP_ID=ordr-connect-group
KAFKA_SSL_ENABLED=false

# --- Authentication ---
JWT_PRIVATE_KEY=              # RS256 private key (PEM) — MUST be from Vault in prod
JWT_PUBLIC_KEY=               # RS256 public key (PEM)
JWT_ACCESS_TOKEN_TTL=900      # 15 minutes in seconds
JWT_REFRESH_TOKEN_TTL=604800  # 7 days in seconds

# --- Encryption (HIPAA §164.312) ---
ENCRYPTION_MASTER_KEY=        # 256-bit key — MUST be from HSM/KMS in prod
ENCRYPTION_KEY_VERSION=1
FIELD_ENCRYPTION_KEY=         # Separate key for field-level PHI encryption

# --- WorkOS (Enterprise SSO/SCIM) ---
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_WEBHOOK_SECRET=

# --- Twilio (Multi-channel) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- SendGrid (Email) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# --- AI/LLM ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_DEFAULT_MODEL=claude-sonnet-4-5-20250514
LLM_BUDGET_MODEL=claude-haiku-4-5-20251001
LLM_PREMIUM_MODEL=claude-opus-4-5-20250514

# --- Neo4j (Customer Graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Monitoring ---
GRAFANA_API_KEY=
PROMETHEUS_PUSH_GATEWAY=
