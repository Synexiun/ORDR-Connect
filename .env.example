# ============================================================
# ORDR-Connect — Environment Variables
#
# COMPLIANCE LAW (CLAUDE.md):
#   - NEVER commit actual secrets. This file shows structure only.
#   - Production secrets MUST come from HashiCorp Vault.
#   - Development secrets go in .env (git-ignored).
#   - Run: cp .env.example .env  then fill in your values.
#
# Variable names here match packages/core/src/config.ts exactly.
# The Zod schema there is the runtime contract — wrong names = crash.
# ============================================================


# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ─────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL 16+ (Rule 1: TLS mandatory in prod)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ordr:change_me@localhost:5432/ordr_connect?sslmode=require
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
# Force TLS on the Drizzle/pg connection. Set false only in dev with local DB.
DATABASE_SSL=false


# ─────────────────────────────────────────────────────────────
# REDIS 7+ — Session cache, rate limiting, real-time scores
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=ordr:


# ─────────────────────────────────────────────────────────────
# KAFKA — Event sourcing backbone (Confluent / local)
# ─────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ordr-connect
KAFKA_GROUP_ID=ordr-connect-group
# Force TLS. Set false only with a local plaintext broker.
KAFKA_SSL=false


# ─────────────────────────────────────────────────────────────
# AUTHENTICATION — JWT (RS256) + Session (Rule 2)
#
# Generate keys:
#   openssl genrsa -out jwt.key 4096
#   openssl rsa -in jwt.key -pubout -out jwt.pub
# Then paste PEM content (newlines preserved as \n in the value).
#
# SESSION_SECRET: 32+ random bytes.
#   Generate: openssl rand -base64 48
# ─────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
SESSION_SECRET=


# ─────────────────────────────────────────────────────────────
# ENCRYPTION — AES-256-GCM + HMAC (Rule 1 — HIPAA §164.312)
#
# ENCRYPTION_MASTER_KEY: 32-byte hex string (256-bit).
#   Generate: openssl rand -hex 32
# HMAC_SECRET: any high-entropy secret (32+ chars).
#   Generate: openssl rand -base64 48
#
# PROD: Both MUST come from HSM/KMS (Vault, AWS KMS, etc.)
# ─────────────────────────────────────────────────────────────
ENCRYPTION_MASTER_KEY=
HMAC_SECRET=


# ─────────────────────────────────────────────────────────────
# AI / LLM
# ─────────────────────────────────────────────────────────────
# OpenAI (required by core config — embeddings + fallback routing)
OPENAI_API_KEY=

# Anthropic (Claude — primary agent reasoning)
ANTHROPIC_API_KEY=

# Model tier overrides
LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_BUDGET_MODEL=claude-haiku-4-5-20251001
LLM_PREMIUM_MODEL=claude-opus-4-6

# Standard AI config (packages/core envSchema)
AI_MODEL=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.1


# ─────────────────────────────────────────────────────────────
# ENTERPRISE SSO — WorkOS (Rule 2: OAuth 2.1 + PKCE)
# https://dashboard.workos.com/api-keys
# ─────────────────────────────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────
# COMMUNICATIONS CHANNELS
# ─────────────────────────────────────────────────────────────
# Twilio — SMS / Voice / IVR
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid — Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=ORDR Connect


# ─────────────────────────────────────────────────────────────
# GRAPH DATABASE — Neo4j Aura (Customer relationship graph)
# ─────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j


# ─────────────────────────────────────────────────────────────
# BILLING — Stripe
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────
# OBSERVABILITY — OpenTelemetry + Sentry + Grafana
# ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=ordr-connect
OTEL_EXPORTER_ENDPOINT=
SENTRY_DSN=
GRAFANA_API_KEY=
PROMETHEUS_PUSH_GATEWAY=


# ─────────────────────────────────────────────────────────────
# FRONTEND (Vite) — apps/web
# In dev, Vite proxies /api → localhost:3000 automatically.
# ─────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api


# ── Vault (Secret Management) ──────────────────────────────────
# Production secrets MUST come from HashiCorp Vault (already deployed on EKS).
# When VAULT_ADDR is absent, all Vault operations are no-ops and the app
# falls back to process.env values (local dev only).
VAULT_ADDR=                          # https://vault.internal:8200
VAULT_ROLE=                          # Kubernetes auth role name (e.g. ordr-api)
VAULT_MOUNT=secret                   # KV v2 mount path (default: secret)
VAULT_POLL_INTERVAL_MS=60000         # Secret polling interval in ms (default: 60 s)
KEY_ROTATION_CHECK_CRON=0 2 * * *   # Daily at 02:00 UTC
