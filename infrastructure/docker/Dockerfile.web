# ORDR-Connect — Web Dashboard Production Dockerfile
# SOC2/ISO27001/HIPAA: static SPA served by nginx, no Node.js in production
# Target: apps/web (React SPA with Vite)

# ============================================================
# Stage 1: Builder — install deps + vite build
# ============================================================
FROM node:22.14-alpine3.20 AS builder

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate
WORKDIR /app

# Copy workspace manifests
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json turbo.json ./

# Copy web app manifest (no @ordr/* runtime deps — pure React SPA)
COPY apps/web/package.json ./apps/web/

RUN pnpm install --frozen-lockfile

# Copy web source
COPY apps/web/ ./apps/web/

RUN pnpm --filter @ordr/web build

# ============================================================
# Stage 2: Runtime — nginx unprivileged, static files only
# ============================================================
FROM nginx:1.27-alpine-slim AS runtime

LABEL org.opencontainers.image.title="ordr-connect-web"
LABEL org.opencontainers.image.description="ORDR-Connect Web Dashboard — React SPA"
LABEL org.opencontainers.image.vendor="Synexiun"
LABEL org.opencontainers.image.version="0.1.0"
LABEL org.opencontainers.image.source="https://github.com/synexiun/ordr-connect"

# Remove default nginx config and static content
RUN rm -rf /usr/share/nginx/html/* /etc/nginx/conf.d/default.conf

# Copy custom nginx config with security headers
COPY infrastructure/docker/nginx.conf /etc/nginx/conf.d/default.conf

# Copy built SPA
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

# Run as nginx user (non-root, uid 101 on Alpine)
USER nginx

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD ["wget", "-q", "--spider", "http://127.0.0.1:8080/", "||", "exit", "1"]

CMD ["nginx", "-g", "daemon off;"]
