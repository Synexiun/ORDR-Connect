# ORDR-Connect — Agent Runtime Production Dockerfile
# SOC2/ISO27001/HIPAA: sandboxed AI execution, non-root, resource-limited
# Target: apps/agent-runtime (LangGraph multi-agent orchestrator)

# ============================================================
# Stage 1: Builder — install deps + compile TypeScript
# ============================================================
FROM node:22.14-alpine3.20 AS builder

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate
WORKDIR /app

# Copy workspace manifests for dependency resolution
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json turbo.json ./

# Copy package.json files for required packages
COPY apps/agent-runtime/package.json ./apps/agent-runtime/
COPY packages/core/package.json ./packages/core/
COPY packages/db/package.json ./packages/db/
COPY packages/ai/package.json ./packages/ai/
COPY packages/compliance/package.json ./packages/compliance/
COPY packages/channels/package.json ./packages/channels/
COPY packages/graph/package.json ./packages/graph/
COPY packages/events/package.json ./packages/events/
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/crypto/package.json ./packages/crypto/
COPY packages/audit/package.json ./packages/audit/
COPY packages/analytics/package.json ./packages/analytics/
COPY packages/decision-engine/package.json ./packages/decision-engine/
COPY packages/auth/package.json ./packages/auth/

RUN pnpm install --frozen-lockfile

# Copy source for build
COPY packages/ ./packages/
COPY apps/agent-runtime/ ./apps/agent-runtime/

RUN pnpm --filter @ordr/agent-runtime... build

# Prune to production deps only
RUN pnpm install --frozen-lockfile --prod

# ============================================================
# Stage 2: Runtime — distroless, sandboxed, resource-capped
# ============================================================
FROM gcr.io/distroless/nodejs22-debian12 AS runtime

LABEL org.opencontainers.image.title="ordr-connect-agent-runtime"
LABEL org.opencontainers.image.description="ORDR-Connect Agent Runtime — AI multi-agent orchestrator"
LABEL org.opencontainers.image.vendor="Synexiun"
LABEL org.opencontainers.image.version="0.1.0"
LABEL org.opencontainers.image.source="https://github.com/synexiun/ordr-connect"

WORKDIR /app

# Copy production artifacts
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./
COPY --from=builder /app/apps/agent-runtime/dist ./apps/agent-runtime/dist
COPY --from=builder /app/apps/agent-runtime/package.json ./apps/agent-runtime/
COPY --from=builder /app/packages/core/dist ./packages/core/dist
COPY --from=builder /app/packages/core/package.json ./packages/core/
COPY --from=builder /app/packages/db/dist ./packages/db/dist
COPY --from=builder /app/packages/db/package.json ./packages/db/
COPY --from=builder /app/packages/ai/dist ./packages/ai/dist
COPY --from=builder /app/packages/ai/package.json ./packages/ai/
COPY --from=builder /app/packages/compliance/dist ./packages/compliance/dist
COPY --from=builder /app/packages/compliance/package.json ./packages/compliance/
COPY --from=builder /app/packages/channels/dist ./packages/channels/dist
COPY --from=builder /app/packages/channels/package.json ./packages/channels/
COPY --from=builder /app/packages/graph/dist ./packages/graph/dist
COPY --from=builder /app/packages/graph/package.json ./packages/graph/
COPY --from=builder /app/packages/events/dist ./packages/events/dist
COPY --from=builder /app/packages/events/package.json ./packages/events/
COPY --from=builder /app/packages/sdk/dist ./packages/sdk/dist
COPY --from=builder /app/packages/sdk/package.json ./packages/sdk/
COPY --from=builder /app/packages/crypto/dist ./packages/crypto/dist
COPY --from=builder /app/packages/crypto/package.json ./packages/crypto/
COPY --from=builder /app/packages/audit/dist ./packages/audit/dist
COPY --from=builder /app/packages/audit/package.json ./packages/audit/

# Copy healthcheck script
COPY --from=builder /app/infrastructure/docker/healthcheck.mjs ./healthcheck.mjs

# Non-root user
USER 1000

ENV NODE_ENV=production
# Cap V8 heap to prevent runaway agent memory consumption
ENV NODE_OPTIONS="--max-old-space-size=2048"

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD ["/nodejs/bin/node", "healthcheck.mjs"]

CMD ["apps/agent-runtime/dist/index.js"]
