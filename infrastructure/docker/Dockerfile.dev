# ORDR-Connect — Development Dockerfile
# For developers who prefer containerized local development

FROM node:22.14-alpine3.20

# Install pnpm via corepack
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

# Install development utilities
RUN apk add --no-cache curl

WORKDIR /app

# Copy workspace configuration first (better layer caching)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json turbo.json ./

# Copy all package.json files for dependency resolution
COPY apps/api/package.json ./apps/api/
COPY apps/worker/package.json ./apps/worker/
COPY apps/agent-runtime/package.json ./apps/agent-runtime/
COPY apps/web/package.json ./apps/web/
COPY apps/developer-portal/package.json ./apps/developer-portal/
COPY packages/core/package.json ./packages/core/
COPY packages/crypto/package.json ./packages/crypto/
COPY packages/audit/package.json ./packages/audit/
COPY packages/auth/package.json ./packages/auth/
COPY packages/events/package.json ./packages/events/
COPY packages/compliance/package.json ./packages/compliance/
COPY packages/db/package.json ./packages/db/
COPY packages/ai/package.json ./packages/ai/
COPY packages/channels/package.json ./packages/channels/
COPY packages/graph/package.json ./packages/graph/
COPY packages/analytics/package.json ./packages/analytics/
COPY packages/decision-engine/package.json ./packages/decision-engine/
COPY packages/sdk/package.json ./packages/sdk/

# Install all dependencies (including devDependencies)
RUN pnpm install --frozen-lockfile

# Copy full source (will be overridden by volume mounts in dev)
COPY . .

EXPOSE 3000

CMD ["pnpm", "dev"]
