{
  "annotations": { "list": [] },
  "description": "ORDR-Connect — Compliance Status: violations, audit events, encryption, key rotation",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Compliance Violations by Regulation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(compliance_violations_total[5m])) by (regulation, severity)",
          "legendFormat": "{{regulation}} ({{severity}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] }
        }
      }
    },
    {
      "title": "Audit Event Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(audit_events_total[5m])) by (action_type)",
          "legendFormat": "{{action_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Encryption Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(encryption_operations_total[5m])) by (operation)",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Total Compliance Violations (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(compliance_violations_total[24h]))",
          "legendFormat": "Violations",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] }
        }
      }
    },
    {
      "title": "Total Audit Events (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(audit_events_total[24h]))",
          "legendFormat": "Audit Events",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Auth Failures (5m window)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=\"401\"}[5m])) by (tenant_id)",
          "legendFormat": "{{tenant_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 10, "color": "red" }] }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ordr-connect", "compliance", "security"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "ORDR-Connect — Compliance Status",
  "uid": "ordr-compliance-status",
  "version": 1
}
