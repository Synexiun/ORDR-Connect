{
  "annotations": { "list": [] },
  "description": "ORDR-Connect — Agent Performance: execution time, tool calls, LLM usage, HITL queue",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Agent Execution Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_execution_duration_seconds_bucket[5m])) by (le, agent_role))",
          "legendFormat": "{{agent_role}} P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_execution_duration_seconds_bucket[5m])) by (le, agent_role))",
          "legendFormat": "{{agent_role}} P95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Tool Call Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(agent_tool_calls_total{success=\"true\"}[5m])) by (tool_name) / sum(rate(agent_tool_calls_total[5m])) by (tool_name) * 100",
          "legendFormat": "{{tool_name}} success %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "title": "LLM Token Usage (Input vs Output)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(llm_tokens_total{type=\"input\"}[5m])) by (model)",
          "legendFormat": "{{model}} input",
          "refId": "A"
        },
        {
          "expr": "sum(rate(llm_tokens_total{type=\"output\"}[5m])) by (model)",
          "legendFormat": "{{model}} output",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "LLM Inference Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_inference_duration_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} P95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Active Agent Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(active_agent_sessions) by (agent_role)",
          "legendFormat": "{{agent_role}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tool Calls per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(agent_tool_calls_total[1m])) by (tool_name) * 60",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ordr-connect", "agents", "ai"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "ORDR-Connect — Agent Performance",
  "uid": "ordr-agent-performance",
  "version": 1
}
