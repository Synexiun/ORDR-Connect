{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordr-connect.synexiun.com/schemas/api-request.json",
  "title": "ORDR-Connect API Request Metadata",
  "description": "Schema for API request logging. SECURITY: No PHI in logged fields — only method, path, correlation ID, timestamp, and safe metadata.",
  "type": "object",
  "required": [
    "method",
    "path",
    "correlationId",
    "timestamp"
  ],
  "properties": {
    "method": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD"],
      "description": "HTTP method"
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^/",
      "description": "Request path — must not contain PHI in query parameters"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "X-Request-Id for distributed tracing"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "tenantId": {
      "type": "string",
      "description": "Tenant scope (from JWT, never from client input)"
    },
    "userId": {
      "type": "string",
      "description": "Authenticated user ID (from JWT)"
    },
    "statusCode": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599,
      "description": "HTTP response status code"
    },
    "durationMs": {
      "type": "number",
      "minimum": 0,
      "description": "Request duration in milliseconds"
    },
    "userAgent": {
      "type": "string",
      "description": "User-Agent header (for client identification)"
    },
    "ipAddress": {
      "type": "string",
      "description": "Client IP address"
    }
  },
  "additionalProperties": false
}
